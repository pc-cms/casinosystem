#!/usr/bin/env bash
#
# Casino System — bootstrap entry point.
# Usage:
#   curl -fsSL https://casinosystem.app/install | sudo bash
#
# This is NOT the full installer. It only locates an existing
# /opt/casino-system tree (unpacked from the USB tarball) and
# delegates to deploy/install.sh.
#
set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'

echo -e "${CYAN}Casino System bootstrap${NC}"

# Re-exec under sudo if not root.
if [[ $EUID -ne 0 ]]; then
  exec sudo bash "$0" "$@"
fi

# Candidate locations for an already-unpacked installer tree.
CANDIDATES=(
  "/opt/casino-system"
  "${PWD:-}"
  "$(dirname "${BASH_SOURCE[0]:-$0}" 2>/dev/null || true)/.."
)

for d in "${CANDIDATES[@]}"; do
  [[ -n "$d" ]] || continue
  if [[ -x "$d/deploy/install.sh" ]]; then
    echo -e "${GREEN}✓${NC} Found installer tree: $d"
    cd "$d"
    exec bash "$d/deploy/install.sh" "$@"
  fi
done

cat >&2 <<EOF
${RED}✗ Casino System project tree not found.${NC}

The bootstrap looks for ${YELLOW}/opt/casino-system/deploy/install.sh${NC}.
Unpack the USB installer first:

  ${CYAN}sudo mkdir -p /opt/casino-system${NC}
  ${CYAN}sudo tar -xzf /media/*/casino-system-installer-*.tar.gz -C /opt/casino-system${NC}
  ${CYAN}curl -fsSL https://casinosystem.app/install | sudo bash${NC}

…then re-run this command, or just call the installer directly:

  ${CYAN}sudo /opt/casino-system/deploy/install.sh${NC}
EOF
exit 1
