# ──────────────────────────────────────────
# GITHUB (для авто-обновлений Docker образа)
# ──────────────────────────────────────────
# Репозиторий с прошивкой и сборкой cms-frontend.
GITHUB_OWNER=pc-cms
GITHUB_REPO=casinosystem

# Personal Access Token с правом read:packages — нужен для docker pull
# из приватного ghcr.io. Создать: github.com/settings/tokens (classic)
# → scopes: read:packages (только это). Если репо/пакет публичные — оставьте ghp_replace_me.
GITHUB_TOKEN=ghp_replace_me

FRONTEND_VERSION=latest
PREVIOUS_VERSION=
CHECK_INTERVAL_MINUTES=60

# Политика обновлений (по умолчанию — только уведомление):
#   AUTO_APPLY=false → cms-updater пишет /compose/UPDATE_AVAILABLE и шлёт алерт
#                      в Cloud (report-health). Админ применяет вручную:
#                        sudo ./install.sh --upgrade-to <version>
#   AUTO_APPLY=true  → авто-подмена контейнера в окно 05:00–06:00 (только если нет
#                      открытых смен). Не рекомендуется для production-казино.
AUTO_APPLY=false

# ──────────────────────────────────────────
# SYNC (cms-sync, этап D) — режим работы локального сервера
# ──────────────────────────────────────────
# SYNC_MODE=hybrid    (по умолчанию) — outbox активен, данные реплицируются в Cloud
# SYNC_MODE=standalone               — изолированное казино, push/pull выключены
SYNC_MODE=hybrid
SYNC_BATCH_SIZE=200
SYNC_INTERVAL_MS=5000

# ──────────────────────────────────────────
# MONITOR / VPN / BACKUP (этап E)
# ──────────────────────────────────────────
MONITOR_INTERVAL_MS=60000
VPN_SUBNET=10.66.0

# Off-site бэкапы → Lovable Cloud Storage (bucket "backups").
# Если CLOUD_URL+SYNC_SECRET доступны — заливка идёт через edge-функцию upload-backup.
# Если связи нет — бэкапы остаются только локально в volume backup_data.
BACKUP_OFFSITE=cloud
BACKUP_RETENTION_DAILY=30
BACKUP_RETENTION_MONTHLY=12
