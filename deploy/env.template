#
# Casino System — On-Premises environment template
# -------------------------------------------------
# Этот файл создаётся install.sh автоматически.
# Все значения, кроме CLOUD_URL/CLOUD_ANON_KEY, заполняются мастером
# или приходят из Cloud при approve. Не редактируйте вручную —
# запускайте `sudo ./install.sh --reconfigure`.
#

# ── КАЗИНО (заполняется мастером + cloud approve) ──
# CASINO_ID — placeholder UUID, совпадает с seed-данными в 20-seed-defaults.sql.
# Меняется только если казино было создано в Cloud и подвязано через pairing.
CASINO_ID=00000000-0000-0000-0000-0000000000ca
CASINO_SLUG=
CASINO_NAME=
LOCAL_DOMAIN=
LOCAL_IP=

# ── СЕКРЕТ СИНХРОНИЗАЦИИ (приходит от Cloud при approve) ──
SYNC_SECRET=

# ── CLOUD endpoint (для pairing + sync) ──
CLOUD_URL=https://rpehngjvwcnipvkouluu.supabase.co
CLOUD_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJwZWhuZ2p2d2NuaXB2a291bHV1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ2OTcwMjAsImV4cCI6MjA5MDI3MzAyMH0.KTJEJRCYpNjj51H28x3pYFLvfMz5qtRjxnUFw3Hnwr0

# ── POSTGRES (генерируется install.sh) ──
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ── JWT (генерируется install.sh) ──
JWT_SECRET=
ANON_KEY=
SERVICE_ROLE_KEY=

# ── FRONTEND (локальная сборка) ──
FRONTEND_VERSION=local

# ── SYNC ──
SYNC_MODE=hybrid
SYNC_BATCH_SIZE=200
SYNC_INTERVAL_MS=5000

# ── MONITOR / VPN / BACKUP ──
MONITOR_INTERVAL_MS=60000
VPN_SUBNET=10.66.0
BACKUP_OFFSITE=cloud
BACKUP_RETENTION_DAILY=30
BACKUP_RETENTION_MONTHLY=12

# ── AUTO-UPDATER (отключён по умолчанию; включается профилем `--profile with-updater`) ──
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_TOKEN=
CHECK_INTERVAL_MINUTES=60
AUTO_APPLY=false

# ── REMOTE ACCESS (Cloudflare Tunnel, опционально) ──
# Получить токен: Cloudflare Zero Trust → Networks → Tunnels → Create tunnel →
# выбрать Docker → скопировать значение после `--token` (длинная base64-строка).
# Включается командой `sudo casino-update --enable-remote`, отключается `--disable-remote`.
# ОБЯЗАТЕЛЬНО накрыть Cloudflare Access policy (email allowlist) — иначе
# в публичный интернет торчит логин-страница локального казино.
# См. deploy/REMOTE-ACCESS.md.
TUNNEL_TOKEN=
