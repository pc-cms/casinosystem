#
# Casino System — On-Premises environment template
# -------------------------------------------------
# Скопируйте в .env и заполните перед запуском install.sh
#   cp env.template .env
#   nano .env
#

# ──────────────────────────────────────────
# КАЗИНО (получить у системного администратора Premier)
# ──────────────────────────────────────────
CASINO_ID=00000000-0000-0000-0000-000000000000
CASINO_SLUG=arusha
LOCAL_DOMAIN=arusha.local

# ──────────────────────────────────────────
# СЕКРЕТ СИНХРОНИЗАЦИИ С CLOUD
# Уникален на казино, выдаётся при регистрации в Premier
# Должен совпадать с записью в local_servers.sync_secret в Cloud
# ──────────────────────────────────────────
SYNC_SECRET=replace-with-32-char-random-secret

# ──────────────────────────────────────────
# POSTGRES
# Пароль генерируется автоматически install.sh, можно оставить пустым
# ──────────────────────────────────────────
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ──────────────────────────────────────────
# JWT (генерируется install.sh)
# ──────────────────────────────────────────
JWT_SECRET=
ANON_KEY=
SERVICE_ROLE_KEY=

# ──────────────────────────────────────────
# GITHUB (для авто-обновлений)
# Создайте Personal Access Token с правами: read:packages
# ──────────────────────────────────────────
GITHUB_OWNER=your-github-org
GITHUB_REPO=casino-system
GITHUB_TOKEN=ghp_replace_me
FRONTEND_VERSION=latest
CHECK_INTERVAL_MINUTES=60
